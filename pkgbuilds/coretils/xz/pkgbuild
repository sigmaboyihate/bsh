name="xz"
version=5.8.2
source="https://github.com/tukaani-project/xz/releases/download/v5.8.2/xz-5.8.2.tar.xz"
confirm=true

build() {
    ./configure --prefix=/usr    \
                --disable-static \
                --docdir=/usr/share/doc/xz-5.8.2
    make
}

check(){
    make check
}

package() {
    make install
}

remove() {
    rm -fv /usr/bin/{xz,xzdec,xzcat,unxz,lzma,lzcat,unlzma,lzmadec,lzmainfo}
    rm -fv /usr/bin/{xzgrep,xzegrep,xzfgrep,lzgrep,lzegrep,lzfgrep}
    rm -fv /usr/bin/{xzdiff,xzcmp,lzdiff,lzcmp,lzless,lzmore,xzless,xzmore}
    rm -fv /usr/lib/liblzma.so*
    rm -rfv /usr/include/lzma /usr/include/lzma.h
    rm -rfv /usr/share/doc/xz-5.8.2
}
