name="binutils"
version=2.46.0
source="https://sourceware.org/pub/binutils/releases/binutils-2.46.0.tar.xz" 
confirm=true

build() {
    mkdir -v build
    cd build
    ../configure --prefix=/usr   \
        --sysconfdir=/etc   \
        --enable-ld=default \
        --enable-plugins    \
        --enable-shared     \
        --disable-werror    \
        --enable-64-bit-bfd \
        --enable-new-dtags  \
        --with-system-zlib  \
        --enable-default-hash-style=gnu

    make tooldir=/usr

}

check(){
    make -k check
    grep '^FAIL:' $(find -name '*.log')
}

install() {
    make tooldir=/usr install
    rm -rfv /usr/lib/lib{bfd,ctf,ctf-nobfd,gprofng,opcodes,sframe}.a \
        /usr/share/doc/gprofng/
}

remove() {
    echo "i wouldn't!"
    echo "but if you switching to busybox or sum, i'd recommend manual removal!" 
}
