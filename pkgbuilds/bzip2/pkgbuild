name="bzip2"
version=1.0.8
source="https://www.sourceware.org/pub/bzip2/bzip2-1.0.8.tar.gz"
patch=("https://www.linuxfromscratch.org/patches/lfs/development/bzip2-1.0.8-install_docs-1.patch")
confirm=true


build() {
    patch -Np1 -i ../bzip2-1.0.8-install_docs-1.patch
    sed -i 's@\(ln -s -f \)$(PREFIX)/bin/@\1@' Makefile
    sed -i "s@(PREFIX)/man@(PREFIX)/share/man@g" Makefile
    make -f Makefile-libbz2_so
    make clean
    make 
}

install() {
    make PREFIX=$DESTDIR/usr install
    cp -av libbz2.so.* $DESTDIR/usr/lib
    ln -sfv libbz2.so.1.0.8 $DESTDIR/usr/lib/libbz2.so
    ln -sfv libbz2.so.1.0.8 $DESTDIR/usr/lib/libbz2.so.1
    cp -v bzip2-shared $DESTDIR/usr/bin/bzip2
    for i in $DESTDIR/usr/bin/{bzcat,bunzip2}; do
        ln -sfv bzip2 $i
    done
    rm -fv $DESTDIR/usr/lib/libbz2.a
}

remove() {
    rm -fv /usr/bin/{bzip2,bzip2recover,bunzip2,bzcat}
    rm -fv /usr/bin/{bzgrep,bzegrep,bzfgrep,bzdiff,bzcmp,bzmore,bzless}
    rm -fv /usr/lib/libbz2.so* /usr/lib/libbz2.so.1*
    rm -fv /usr/include/bzlib.h
    rm -rfv /usr/share/doc/bzip2-1.0.8
    rm -fv /usr/share/man/man1/bzip2*
}
