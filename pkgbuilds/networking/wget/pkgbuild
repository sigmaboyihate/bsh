name="wget"
version=1.25.0
source="https://ftp.gnu.org/gnu/wget/wget-1.25.0.tar.gz"
md5sum="c70ba58b36f944e8ba1d655ace552881"
# don't forget to add depends for the yk yeah 

build() {
    ./configure --prefix=/usr      \
                --sysconfdir=/etc  \
                --with-ssl=openssl
    make
}

package(){
    make DESTDIR="$DESTDIR" install # yayy
}
