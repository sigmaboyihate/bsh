name="zlib"
version=1.3.2
source="https://github.com/madler/zlib/releases/download/v1.3.2/zlib-1.3.2.tar.gz"
confirm=true

build() {
    ./configure --prefix=/usr
    make
}

check() {
    make check 
} 

install() {
    make install
    rm -fv $DESTDIR/usr/lib/libz.a
}

remove() {
    echo "i wouldn't do this on either!!!"
}
