name="glibc"
version=2.43
source="https://ftpmirror.gnu.org/glibc/glibc-2.43.tar.xz"
patch=("https://www.linuxfromscratch.org/patches/lfs/development/glibc-fhs-1.patch")
confirm=true

build() {
    patch -Np1 -i ../glibc-fhs-1.patch
    mkdir -v build
    cd build
    echo "rootsbindir=/usr/sbin" > configparms
   
    ../configure --prefix=/usr                   \
                 --disable-werror                \
                 --disable-nscd                  \
                 libc_cv_slibdir=/usr/lib        \
                 --enable-stack-protector=strong \
                 --enable-kernel=5.4
    make
}

check(){
    make check
}

install() {
    sed '/test-installation/s@$(PERL)@echo not running@' -i Makefile
    
    # to not fuck over! 
    make DESTDIR=$PWD/dest install
    install -vm755 dest/usr/lib/*.so.* /usr/lib

    make install
    sed '/RTLDLIST=/s@/usr@@g' -i /usr/bin/ldd
}

remove() {
    echo "i wouldn't!"
    echo "but if you switching to busybox or sum, i'd recommend manual removal!" 
}
