name="file"
version=5.46
source="https://astron.com/pub/file/file-5.46.tar.gz"

build() {
    ./configure --prefix=/usr
    make
}


install() {
    make install
}

remove() {
    rm -fv /usr/bin/file
    rm -fv /usr/lib/libmagic.so*
    rm -fv /usr/include/magic.h
    rm -rfv /usr/share/misc/magic* /usr/share/file
    rm -fv /usr/share/man/man1/file.1
    rm -fv /usr/share/man/man3/libmagic.3
}
