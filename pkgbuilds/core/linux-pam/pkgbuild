name="linux-pam"
version=1.7.2
source="https://github.com/linux-pam/linux-pam/releases/download/v1.7.2/Linux-PAM-1.7.2.tar.xz"
md5sum="934c26eca3fada956356a30489e86291"

build(){
    mkdir build 
    cd build 

    meson setup ..        \
      --prefix=/usr       \
      --buildtype=release \
      -D docdir=/usr/share/doc/Linux-PAM-1.7.2 

    ninja
}

package() {
    cd build
    DESTDIR="$DESTDIR" ninja install
    chmod -v 4755 $DESTDIR/usr/sbin/unix_chkpwd
}

postpackage() {
    install -vdm755 /etc/pam.d

    [ ! -f /etc/pam.d/system-account ] && cat > /etc/pam.d/system-account << "EOF"
# Begin /etc/pam.d/system-account
account   required    pam_unix.so
# End /etc/pam.d/system-account
EOF

    [ ! -f /etc/pam.d/system-auth ] && cat > /etc/pam.d/system-auth << "EOF"
# Begin /etc/pam.d/system-auth
auth      required    pam_unix.so
# End /etc/pam.d/system-auth
EOF

    [ ! -f /etc/pam.d/system-session ] && cat > /etc/pam.d/system-session << "EOF"
# Begin /etc/pam.d/system-session
session   required    pam_unix.so
# End /etc/pam.d/system-session
EOF

    [ ! -f /etc/pam.d/system-password ] && cat > /etc/pam.d/system-password << "EOF"
# Begin /etc/pam.d/system-password
password  required    pam_unix.so       yescrypt shadow try_first_pass
# End /etc/pam.d/system-password
EOF
    cat > /etc/pam.d/other << "EOF"
# Begin /etc/pam.d/other
auth        required        pam_warn.so
auth        required        pam_deny.so
account     required        pam_warn.so
account     required        pam_deny.so
password    required        pam_warn.so
password    required        pam_deny.so
session     required        pam_warn.so
session     required        pam_deny.so
# End /etc/pam.d/other
EOF
}