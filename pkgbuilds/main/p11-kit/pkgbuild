name="p11-kit"
version=0.26.2
source="https://github.com/p11-glue/p11-kit/releases/download/0.26.2/p11-kit-0.26.2.tar.xz"
depends=(libtasn1)
sha256sum="09fd9f44da4813a3141e73d5e7cf7008e5660d0405f13d56c15e1da9dcecf828"

build() {
    sed '20,$ d' -i trust/trust-extract-compat &&
    cat >> trust/trust-extract-compat << "EOF"
/usr/libexec/make-ca/copy-trust-modifications
# Update trust stores
/usr/sbin/make-ca -r
EOF
    mkdir p11-build
    cd p11-build
    meson setup ..            \
          --prefix=/usr       \
          --buildtype=release \
          -D trust_paths=/etc/pki/anchors &&
    ninja
}

package() {
    DESTDIR="$DESTDIR" ninja install
    ln -sfv $DESTDIR/usr/libexec/p11-kit/trust-extract-compat \
            $DESTDIR/usr/bin/update-ca-certificates
}
