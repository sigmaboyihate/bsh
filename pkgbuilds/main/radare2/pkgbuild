name="radare2"
version=6.1.0
source="https://github.com/radareorg/radare2/releases/download/6.1.0/radare2-6.1.0.tar.xz"
sha256sum="8dc333bb114b80adabe6133ca8d649b169151c477c4f167579f5d877f9cf4c3a"

build() {
    ./configure --prefix=/usr
    make
} 

package(){
   make DESTDIR="$DESTDIR" install
}



