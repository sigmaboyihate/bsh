name="icu"
version=78.2
source="https://github.com/unicode-org/icu/releases/download/release-$version/icu4c-$version-sources.tgz"
md5sum="2bf8db43ccdc837e402ac773f17c7cf8"

build(){
    cd source                 
    ./configure --prefix=/usr 
    make
}

package(){
    make DESTDIR="$DESTDIR" install
}