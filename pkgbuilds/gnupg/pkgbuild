name="gnupg"
version=2.5.17
source="https://www.gnupg.org/ftp/gcrypt/gnupg/gnupg-2.5.17.tar.bz2"
confirm=true

build() {
    mkdir build 
    cd build 

    ../configure --prefix=/usr        \
                 --localstatedir=/var \
                 --sysconfdir=/etc    \
                 --docdir=/usr/share/doc/gnupg-2.5.17 
    
    make

}

install() {
    make install
}

remove() {
    rm -rf /usr/share/gnupg
    rm -rf /usr/share/doc/gnupg-2.5.17

    rm -f /usr/bin/addgnupghome \
          /usr/bin/applygnupgdefaults \
          /usr/bin/dirmngr \
          /usr/bin/dirmngr-client \
          /usr/bin/g13 \
          /usr/bin/gpg-agent \
          /usr/bin/gpg-card \
          /usr/bin/gpg-connect-agent \
          /usr/bin/gpg \
          /usr/bin/gpgconf \
          /usr/bin/gpgparsemail \
          /usr/bin/gpgscm \
          /usr/bin/gpgsm \
          /usr/bin/gpgsplit \
          /usr/bin/gpgtar \
          /usr/bin/gpgv \
          /usr/bin/gpg-wks-client \
          /usr/bin/gpg-wks-server \
          /usr/bin/kbxutil \
          /usr/bin/watchgnupg
}
