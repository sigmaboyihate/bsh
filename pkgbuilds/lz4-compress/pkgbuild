name="lz4"
version=1.10.0
source="https://github.com/lz4/lz4/releases/download/v1.10.0/lz4-1.10.0.tar.gz"

build() {
    make BUILD_STATIC=no PREFIX=/usr
}

# feel free to add check, i don't think its important here

install() {
    make BUILD_STATIC=no PREFIX=/usr install
}

remove() {
    rm -fv /usr/bin/{lz4,lz4c,lz4cat,unlz4}
    rm -fv /usr/lib/liblz4.so*
    rm -fv /usr/include/lz4*.h
}
