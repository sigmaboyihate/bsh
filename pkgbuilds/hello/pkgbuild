name="hello"
version=2.12
source="https://ftp.gnu.org/gnu/hello/hello-2.12.tar.gz"
depends=(cmatrix)

build() {
    ./configure --prefix=/usr
    make
}

install() {
    make install
}

remove() {
    rm -f /usr/bin/hello
    rm -f /usr/share/man/man1/hello.1
    rm -f /usr/share/info/hello.info 
}
